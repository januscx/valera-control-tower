<?xml version="1.0"?>
<robot name="valera_trackbot_wiper_v2">
  <!--
    Geometry reconstructed from trackbot wiper v25.step (Fusion revision 26).
    ROS frame: +X forward, +Y left, +Z up. Units are SI.

    The tread shoes are fixed visual geometry. Four cylindrical contact wheels
    provide a stable skid-steer physics approximation in Isaac Sim. The rear
    pair is driven; the front pair is passive.
  -->

  <material name="chassis_white">
    <color rgba="0.82 0.80 0.72 1.0"/>
  </material>
  <material name="printed_black">
    <color rgba="0.035 0.035 0.04 1.0"/>
  </material>

  <link name="base_link">
    <inertial>
      <!-- Estimated mass includes motors, batteries, rods and electronics. -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="7.6"/>
      <inertia ixx="0.07473" ixy="0" ixz="0"
               iyy="0.16904" iyz="0" izz="0.22236"/>
    </inertial>
    <visual name="chassis_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/base.stl" scale="1 1 1"/>
      </geometry>
      <material name="chassis_white"/>
    </visual>
    <collision name="chassis_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.500 0.318 0.130"/>
      </geometry>
    </collision>
  </link>

  <link name="left_track_visual_link">
    <inertial>
      <origin xyz="0 0.188 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.00790" ixy="0" ixz="0"
               iyy="0.04085" iyz="0" izz="0.03881"/>
    </inertial>
    <visual name="left_track_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/left_track.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
  </link>

  <joint name="left_track_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_track_visual_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="right_track_visual_link">
    <inertial>
      <origin xyz="0 -0.188 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.00790" ixy="0" ixz="0"
               iyy="0.04085" iyz="0" izz="0.03881"/>
    </inertial>
    <visual name="right_track_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/right_track.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
  </link>

  <joint name="right_track_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_track_visual_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="left_front_idler_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.001194" ixy="0" ixz="0"
               iyy="0.002318" iyz="0" izz="0.001194"/>
    </inertial>
    <visual name="left_front_idler_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/left_front_idler.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
    <collision name="left_front_contact">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.115" length="0.163"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_front_idler_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_front_idler_link"/>
    <origin xyz="0.1850 0.18855 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="4.0" velocity="4.0"/>
    <dynamics damping="0.08" friction="0.03"/>
  </joint>

  <link name="right_front_idler_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.001194" ixy="0" ixz="0"
               iyy="0.002318" iyz="0" izz="0.001194"/>
    </inertial>
    <visual name="right_front_idler_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/right_front_idler.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
    <collision name="right_front_contact">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.115" length="0.163"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_front_idler_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_front_idler_link"/>
    <origin xyz="0.1850 -0.18855 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="4.0" velocity="4.0"/>
    <dynamics damping="0.08" friction="0.03"/>
  </joint>

  <link name="left_rear_drive_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.75"/>
      <inertia ixx="0.002073" ixy="0" ixz="0"
               iyy="0.003863" iyz="0" izz="0.002073"/>
    </inertial>
    <visual name="left_rear_drive_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/left_rear_drive.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
    <collision name="left_rear_contact">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.115" length="0.163"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_rear_drive_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_rear_drive_link"/>
    <origin xyz="-0.1850 0.18880 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="30.0" velocity="2.5"/>
    <dynamics damping="0.35" friction="0.08"/>
  </joint>

  <link name="right_rear_drive_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.75"/>
      <inertia ixx="0.002073" ixy="0" ixz="0"
               iyy="0.003863" iyz="0" izz="0.002073"/>
    </inertial>
    <visual name="right_rear_drive_visual">
      <geometry>
        <mesh filename="package://trackbot_description/meshes/visual/right_rear_drive.stl" scale="1 1 1"/>
      </geometry>
      <material name="printed_black"/>
    </visual>
    <collision name="right_rear_contact">
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.115" length="0.163"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_rear_drive_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_rear_drive_link"/>
    <origin xyz="-0.1850 -0.18880 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="30.0" velocity="2.5"/>
    <dynamics damping="0.35" friction="0.08"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <link name="gps_link"/>
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="0.0001 0.0250 0.1910" rpy="0 0 0"/>
  </joint>
  <!--
    SO-101 follower mount reconstructed from the supplied photographs.
    Mount centre relative to base_link: 165 mm forward, 90 mm right,
    on the 65 mm-high chassis top plane. Zero yaw makes the arm face +X.
    Arm geometry: TheRobotStudio/SO-ARM100, new-calibration URDF,
    commit fda892cba81032c46c40976a48c9ceadbf40a9ca (Apache-2.0).
  -->

  <joint name="so101_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="so101_base_link"/>
    <origin xyz="0.120 -0.075 0.065" rpy="0 0 0"/>
  </joint>


  <!-- Materials -->
  <material name="so101_red">
    <color rgba="0.82 0.015 0.01 1.0"/>
  </material>
  <material name="sts3215">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="parallel_gripper_gray">
    <color rgba="0.26 0.28 0.31 1.0"/>
  </material>

