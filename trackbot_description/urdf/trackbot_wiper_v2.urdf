              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="parallel_gripper_gray"/>
    </visual>
    <collision>
      <origin xyz="-0.079890 0.342905 0.031809" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://trackbot_description/meshes/parallel_gripper/collision/clamp_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- Servo-driven jaw; 37 mm travel. -->
  <joint name="gripper" type="prismatic">
    <origin xyz="-0.1832804 -0.0611257 -0.2200763"
            rpy="1.5707992 0.0000037 1.6194758"/>
    <parent link="gripper_link"/>
    <child link="right_clamp_link"/>
    <axis xyz="0.999848 -0.000154 0.017451"/>
    <limit effort="60" velocity="0.014" lower="0.0" upper="0.037"/>
    <dynamics damping="20" friction="2"/>
  </joint>

  <!-- Opposite jaw mirrors the servo-driven jaw. -->
  <joint name="left_clamp" type="prismatic">
    <origin xyz="-0.1872016 0.0637935 -0.2222778"
            rpy="1.5707992 0.0000037 1.6194758"/>
    <parent link="gripper_link"/>
    <child link="left_clamp_link"/>
    <axis xyz="0.999848 -0.000154 0.017451"/>
    <limit effort="60" velocity="0.014" lower="-0.038" upper="0.0"/>
    <dynamics damping="20" friction="2"/>
    <mimic joint="gripper" multiplier="-1" offset="0"/>
  </joint>

  <!-- Tool-centre point at the midpoint of the jaw tips. -->
  <link name="gripper_frame_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1e-9"/>
      <inertia ixx="1e-12" ixy="0" ixz="0"
               iyy="1e-12" iyz="0" izz="1e-12"/>
    </inertial>
  </link>

  <joint name="gripper_frame_joint" type="fixed">
    <origin xyz="0 0 -0.13179" rpy="0 3.14159 0"/>
    <parent link="gripper_link"/>
    <child link="gripper_frame_link"/>
  </joint>

  <!-- Joint from wrist to gripper -->
  <joint name="wrist_roll" type="revolute">
    <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="5.236" lower="-2.74385" upper="2.84121"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <!-- Joint from lower_arm to wrist -->
  <joint name="wrist_flex" type="revolute">
    <origin xyz="-0.1349 0.0052 3.62355e-17" rpy="4.02456e-15 8.67362e-16 -1.5708"/>
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="5.236" lower="-1.65806" upper="1.65806"/>
    <dynamics damping="0.10" friction="0.03"/>
  </joint>

  <!-- Joint from upper_arm to lower_arm -->
  <!-- Note: 5-degree calibration offset applied to joint limits -->
  <joint name="elbow_flex" type="revolute">
    <origin xyz="-0.11257 -0.028 1.73763e-16" rpy="-3.63608e-16 8.74301e-16 1.5708"/>
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="5.236" lower="-1.69" upper="1.69"/>
    <dynamics damping="0.12" friction="0.04"/>
  </joint>

  <!-- Joint from shoulder to upper_arm -->
  <joint name="shoulder_lift" type="revolute">
    <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="5.236" lower="-1.74533" upper="1.74533"/>
    <dynamics damping="0.16" friction="0.05"/>
  </joint>

  <!-- Joint from base to shoulder -->
  <joint name="shoulder_pan" type="revolute">
    <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 4.18253e-17 -3.14159"/>
    <parent link="so101_base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.5" velocity="5.236" lower="-1.91986" upper="1.91986"/>
    <dynamics damping="0.12" friction="0.04"/>
  </joint>

</robot>
