  <!--
    Robonine SO-ARM100/101 Parallel Gripper, adapted to the upstream SO-101
    wrist frame. Source commit 3e6befa7c82a720df1f48587b38fe562fc67f2cc
    (GPL-3.0). The primary prismatic joint keeps the canonical name
    "gripper" for compatibility with existing SO-101 control mappings.
  -->
  <link name="gripper_link">
    <inertial>
      <!-- 120 g main body; conservative box-equivalent inertia. -->
      <origin xyz="0.0296384 -0.0000770 -0.0332199" rpy="0 0 0"/>
      <mass value="0.120"/>
      <inertia ixx="0.000220065" ixy="0" ixz="0"
               iyy="0.000177128" iyz="0" izz="0.000291986"/>
